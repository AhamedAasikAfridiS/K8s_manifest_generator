# AI Agent Service Environment Configuration
APP_NAME=K8s Manifest AI Agent Service
APP_ENV=development
DEBUG=true

# Server
HOST=0.0.0.0
PORT=8002

# JWT (must match auth service)
JWT_SECRET_KEY=change-this-to-a-long-random-secret-in-production
JWT_ALGORITHM=HS256

# OpenAI / compatible API
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
USE_MOCK_LLM=true

# Storage
UPLOAD_DIR=uploads
GENERATED_DIR=generated
MAX_UPLOAD_SIZE_MB=10

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Validation tools (optional - set paths if installed in container)
KUBE_SCORE_PATH=kube-score
KUBE_LINTER_PATH=kube-linter
ENABLE_KUBE_SCORE=true
ENABLE_KUBE_LINTER=true
